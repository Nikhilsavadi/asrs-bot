FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements.ftse.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy bot code
COPY ftse_bot/ ftse_bot/
COPY telegram_cmd.py .

# Create data directory
RUN mkdir -p data

HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "import os, signal; pid=int(open('/tmp/ftse.pid').read()); os.kill(pid, 0)" || exit 1

CMD ["python", "-m", "ftse_bot.main"]
